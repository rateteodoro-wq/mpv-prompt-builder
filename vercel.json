{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://impactprodutividade.com.br https://www.impactprodutividade.com.br;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://impactprodutividade.com.br"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}

